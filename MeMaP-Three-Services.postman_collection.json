                  "raw": "{{base_learning}}/api/v1/quizzes/my-quizzes?page=0&size=10&sortBy=createdAt&sortDir=desc",
                  "host": ["{{base_learning}}"],
                  "path": ["api", "v1", "quizzes", "my-quizzes"],
                  "query": [
                    { "key": "roadmapId", "value": "", "disabled": true },
                    { "key": "visible", "value": "", "disabled": true },
                    { "key": "search", "value": "", "disabled": true },
                    { "key": "page", "value": "0" },
                    { "key": "size", "value": "10" },
