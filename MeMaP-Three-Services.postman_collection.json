{
  "info": {
    "name": "MeMaP - Profile, Roadmap & Learning Services",
    "description": "Postman collection for Profile Service (8082), Roadmap Service (8083), and Learning Service (8089).\n\n## Setup\n1. Import this collection\n2. Select the environment **MeMaP Local**\n3. Call **Login** first — the `token` variable is set automatically via the test script\n4. All other requests use `{{token}}` via Bearer auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_profile",  "value": "http://localhost:8082/profile",   "type": "string" },
    { "key": "base_roadmap",  "value": "http://localhost:8083/road-map",  "type": "string" },
    { "key": "base_learning", "value": "http://localhost:8089/learning",  "type": "string" },
    { "key": "token",         "value": "",                                 "type": "string" },
    { "key": "userId",        "value": "",                                 "type": "string" },
    { "key": "roadmapId",     "value": "",                                 "type": "string" },
    { "key": "nodeId",        "value": "",                                 "type": "string" },
    { "key": "edgeId",        "value": "",                                 "type": "string" },
    { "key": "categoryId",    "value": "",                                 "type": "string" },
    { "key": "quizId",        "value": "",                                 "type": "string" },
    { "key": "questionId",    "value": "",                                 "type": "string" },
    { "key": "attemptId",     "value": "",                                 "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [

    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res && res.result && res.result.accessToken) {",
                  "    pm.collectionVariables.set('token', res.result.accessToken);",
                  "    console.log('Token set successfully');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"your-username\",\n  \"password\": \"your-password\"\n}"
            },
            "url": { "raw": "{{base_profile}}/authentication/login", "host": ["{{base_profile}}"], "path": ["authentication", "login"] }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res && res.result && res.result.accessToken) {",
                  "    pm.collectionVariables.set('token', res.result.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_profile}}/authentication/refresh-token", "host": ["{{base_profile}}"], "path": ["authentication", "refresh-token"] }
          }
        }
      ]
    },

    {
      "name": "👤 Profile Service",
      "item": [

        {
          "name": "User Management",
          "item": [
            {
              "name": "Register User",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"johndoe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"gender\": \"MALE\",\n  \"dateOfBirth\": \"1995-05-15\",\n  \"phoneNumber\": \"+1234567890\"\n}"
                },
                "url": { "raw": "{{base_profile}}/users/register", "host": ["{{base_profile}}"], "path": ["users", "register"] }
              }
            },
            {
              "name": "Get My Profile",
              "request": {
                "method": "GET",
                "header": [],
                "url": { "raw": "{{base_profile}}/users/my-profile", "host": ["{{base_profile}}"], "path": ["users", "my-profile"] }
              }
            },
            {
              "name": "Update Profile",
              "request": {
                "method": "PUT",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe Updated\",\n  \"phoneNumber\": \"+1234567890\",\n  \"dateOfBirth\": \"1995-05-15\",\n  \"bio\": \"Passionate learner and teacher\",\n  \"gender\": \"MALE\"\n}"
                },
                "url": { "raw": "{{base_profile}}/users", "host": ["{{base_profile}}"], "path": ["users"] }
              }
            },
            {
              "name": "Remove User (Soft Delete)",
              "request": {
                "method": "PATCH",
                "header": [],
                "url": { "raw": "{{base_profile}}/users/remove/{{userId}}", "host": ["{{base_profile}}"], "path": ["users", "remove", "{{userId}}"] }
              }
            },
            {
              "name": "Change Password",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"oldPassword\": \"OldPass123!\",\n  \"newPassword\": \"NewPass456!\"\n}"
                },
                "url": { "raw": "{{base_profile}}/users/change-password", "host": ["{{base_profile}}"], "path": ["users", "change-password"] }
              }
            },
            {
              "name": "Forgot Password",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"john@example.com\"\n}"
                },
                "url": { "raw": "{{base_profile}}/users/forgot-password", "host": ["{{base_profile}}"], "path": ["users", "forgot-password"] }
              }
            },
            {
              "name": "Update Avatar",
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "formdata",
                  "formdata": [{ "key": "file", "type": "file", "src": "" }]
                },
                "url": { "raw": "{{base_profile}}/users/update-avatar", "host": ["{{base_profile}}"], "path": ["users", "update-avatar"] }
              }
            },
            {
              "name": "Search Users by Email",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{base_profile}}/users?page=0&size=10&email=john",
                  "host": ["{{base_profile}}"],
                  "path": ["users"],
                  "query": [
                    { "key": "page", "value": "0" },
                    { "key": "size", "value": "10" },
                    { "key": "email", "value": "john" },
                    { "key": "userId", "value": "", "disabled": true }
                  ]
                }
              }
            },
            {
              "name": "Get Users in Bulk",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"userIds\": [\n    \"uuid-1\",\n    \"uuid-2\",\n    \"uuid-3\"\n  ]\n}"
                },
                "url": { "raw": "{{base_profile}}/users/bulk", "host": ["{{base_profile}}"], "path": ["users", "bulk"] }
              }
            }
          ]
        }

      ]
    },

