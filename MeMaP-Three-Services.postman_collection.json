    {
      "name": "📚 Learning Service",
      "item": [

        {
          "name": "Quiz Management (TEACHER)",
          "item": [
            {
              "name": "Create Quiz",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "var res = pm.response.json();",
                      "if (res && res.result) {",
                      "    var id = res.result.id || res.result.quizId;",
                      "    if (id) pm.collectionVariables.set('quizId', id);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"JavaScript Fundamentals\",\n  \"description\": \"Test variables, functions, and control flow.\",\n  \"roadmapId\": \"{{roadmapId}}\",\n  \"difficulty\": \"EASY\",\n  \"timeLimitMins\": 10,\n  \"passingScore\": 70.0,\n  \"maxAttempts\": 3,\n  \"startDate\": \"2026-02-01T08:00:00\",\n  \"endDate\": \"2026-12-31T23:59:00\",\n  \"visible\": false\n}"
                },
                "url": { "raw": "{{base_learning}}/api/v1/quizzes", "host": ["{{base_learning}}"], "path": ["api", "v1", "quizzes"] }
              }
            },
